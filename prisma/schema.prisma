generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}
model Ranking {
  name        String
  code        String   @id
  date        DateTime @default(now())
  creator     String
  public      Boolean  @default(false)
  elements    Int?     @db.SmallInt
  votes       Int   @default(0)
  items       Item[]
}
model Item {
  id          BigInt  @id @default(autoincrement())
  name        String
  points      Int     @default(1000)
  rankingCode String
  ranking     Ranking @relation(fields: [rankingCode], references: [code])
}
